{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "outDir": "dist",
    "paths": {
      "src/*": ["src/*"],
      "components/*": ["src/components/*"]
    },
    "resolveJsonModule": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "target": "esnext"
  },
  "include": ["src/**/*", "src/types/**/*.d.ts", "vitest.setup.ts"],
  "exclude": ["**/*.spec.ts"]
}
